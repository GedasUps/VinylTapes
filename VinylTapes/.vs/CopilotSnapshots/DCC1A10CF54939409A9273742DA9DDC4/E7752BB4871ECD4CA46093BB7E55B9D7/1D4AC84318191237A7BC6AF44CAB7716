using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using Pgvector.EntityFrameworkCore;
using VinylTapes.Data;
using VinylTapes.Models;
using VinylTapes.Services;
using VinylTapes.Shared.Models; // Naudojame Shared modelius


[ApiController]
[Route("api/[controller]")]
public class VinylController : ControllerBase
{
    private readonly DiscogsService _discogsService;
    private readonly VinylDbContext _context;
    private readonly VectorService _vectorService;


    public VinylController(DiscogsService discogsService, VinylDbContext context, VectorService vectorService)
    {
        _discogsService = discogsService;
        _context = context;
        _vectorService = vectorService;
    }

    [HttpPost("add-by-id/{id}")]
    public async Task<IActionResult> AddVinyl(int id, string token, string secret)
    {
        // Patikriname, ar tokia plokštelė jau yra DB, kad nedubliuotume
        var existing = await _context.Ploksteles.FindAsync(id);
        if (existing != null) return Conflict("Ši plokštelė jau užregistruota.");

        var plokstele =  await _discogsService.GetRecordFromDiscogsAsync(id, token, secret);
        if (plokstele == null) return NotFound("Nepavyko gauti duomenų iš Discogs.");
        _context.Ploksteles.Add(plokstele);
        await _context.SaveChangesAsync();

        return Ok(plokstele);
    }

    [HttpGet("{id}")]
    public async Task<ActionResult<PloksteleDto>> GetVinyl(int id)
    {
        var p = await _context.Ploksteles
            .Include(x => x.Dainas)
            .FirstOrDefaultAsync(x => x.Discogsid == id);

        if (p == null) return NotFound();

        // KONVERTAVIMAS: Entity -> DTO
        // Čia vyksta magija: paverčiame DB objektą į tai, ką supranta naršyklė
        return new PloksteleDto
        {
            DiscogsId = p.Discogsid,
            Atlikejas = p.Atlikejas,
            Albumas = p.Albumas,
            Metai = p.Metai,
            Vektorius = p.Vektorius?.ToArray().ToList(), 
            Dainos = p.Dainas.Select(d => new DainaDto
            {
                Pavadinimas = d.Pavadinimas,
                Pozicija = d.Pozicija,
                Trukme = d.Trukme
            }).ToList()
        };
    }
    [HttpGet("preview/{id}")]
    public async Task<ActionResult<PloksteleDto>> GetPreview(int id, string el_pastas)
    {
        
        if (string.IsNullOrEmpty(el_pastas))
            el_pastas = "user@example.com";
        if (!_context.Naudotojais.Any(u => u.ElPastas == el_pastas))
            return BadRequest("Naudotojas nerastas.");
       string zetonas= _context.Naudotojais.Find(el_pastas).DisgocsZetonas??"";
       string paslaptis= _context.Naudotojais.Find(el_pastas).DiscogsPaslaptis??"";
        var p = await _discogsService.GetRecordFromDiscogsAsync(id, zetonas, paslaptis);
        if (p == null) return NotFound();

        return Ok(p);
    }

    [HttpPost("add")]
    public async Task<IActionResult> RegisterVinyl([FromBody] VinylRegistrationRequest req)
    {
        // 1. Paimame info iš Discogs
        var plokstele = await _discogsService.GetRecordFromDiscogsAsync(req.DiscogsId, "...", "...");

        // 2. Priskiriame papildomus duomenis
        plokstele.Busena = req.ConditionId;
        plokstele.IsigijimoKaina = req.Price;

        // 3. Išsaugome
        _context.Ploksteles.Add(plokstele);
        await _context.SaveChangesAsync();

        return Ok();
    }

    // Pagalbinė klasė užklausai
    public class VinylRegistrationRequest
    {
        public int DiscogsId { get; set; }
        public int ConditionId { get; set; }
        public decimal Price { get; set; }
    }


}