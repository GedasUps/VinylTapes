<div class="w-full max-w-3xl mx-auto mb-16">
    <div class="bg-white rounded-full shadow-2xl p-2 flex items-center border border-gray-50">
        <div class="pl-5 pr-3 text-gray-400">
            @if (IsSemantic)
            {
                <span class="text-indigo-500 font-bold">✨</span>
            }
            else
            {

                <span class="oi oi-magnifying-glass"></span>
            }
        </div>

        <input type="text"
               @bind="Query"
               @bind:event="oninput"
               @onkeyup="HandleKeyUp"
               placeholder="@(IsSemantic ? "Ieškokite pagal nuotaiką (pvz: ramus vakaras)..." : "Atlikėjas, albumas...")"
               class="flex-grow outline-none text-lg text-gray-700 bg-transparent" />

        <div class="bg-gray-100 rounded-full p-1 flex gap-1">
            <button @onclick="() => SetSemantic(false)"
                    class="px-5 py-2 rounded-full text-sm font-bold transition-all @(!IsSemantic ? "bg-white shadow-sm text-gray-900" : "text-gray-400")">
                Tekstinė
            </button>
            <button @onclick="() => SetSemantic(true)"
                    class="px-5 py-2 rounded-full text-sm font-bold transition-all @(IsSemantic ? "bg-indigo-600 text-white shadow-md" : "text-gray-400")">
                Semantinė
            </button>
        </div>
    </div>
</div>

@code {
    private string Query { get; set; } = "";
    private bool IsSemantic { get; set; } = false;

    [Parameter] public EventCallback<(string query, bool isSemantic)> OnSearch { get; set; }

    private void SetSemantic(bool val) => IsSemantic = val;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnSearch.InvokeAsync((Query, IsSemantic));
        }
    }
}