@using VinylTapes.Shared.Models


<div class="floating-card bg-white p-6 shadow-lg border border-gray-100 flex flex-col gap-4 w-full max-w-sm">
    <div class="relative group">
        <img src="@(string.IsNullOrEmpty(Record.ImageUrl) ? "https://via.placeholder.com/300" : Record.ImageUrl)"
             class="w-full aspect-square object-cover rounded-3xl shadow-inner" />

        <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-md px-4 py-1 rounded-full text-xs font-bold text-indigo-600">
            @Record.busena
        </div>
    </div>

    <div class="flex flex-col gap-1">
        <h3 class="text-xl font-black text-gray-900 truncate">@Record.Albumas</h3>
        <p class="text-gray-500 font-medium">@Record.Atlikejas</p>
    </div>

    <div class="flex justify-between items-center mt-2">
        <div class="text-gray-400 text-sm flex items-center gap-1">
            <span class="oi oi-disc"></span> @Record.Metai
        </div>
        <span class="text-2xl font-black text-indigo-600">@Record.IsigijimoKaina €</span>
    </div>

    <button class="w-full bg-gray-50 hover:bg-indigo-600 hover:text-white py-4 rounded-2xl font-bold transition-all text-gray-600 text-sm uppercase tracking-widest">
        Siūlyti Mainus
    </button>
</div>

@code {
    [Parameter] public PloksteleDto Record { get; set; } = null!;
}
 
