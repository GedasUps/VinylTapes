@page "/start"
@using VinylTapes.Shared.Models
@inject HttpClient Http

<div class="p-8">
    <button @onclick="LoadVinyl" class="bg-indigo-600 text-white px-4 py-2 rounded">
        Užkrauti Pink Floyd
    </button>

    @if (vinyl != null)
    {
        <div class="mt-8 p-6 bg-white shadow-2xl rounded-[2rem]">
            <h1 class="text-2xl font-bold">@vinyl.Albumas</h1>
            <p class="text-gray-500">@vinyl.Atlikejas (@vinyl.Metai)</p>

            <h3 class="mt-4 font-bold">Dainos:</h3>
            <ul>
                @foreach (var d in vinyl.Dainos)
                {
                    <li>@d.Pozicija - @d.Pavadinimas (@d.Trukme)</li>
                }
            </ul>
        </div>
    }
</div>

@code {
    private PloksteleDto? vinyl;

    private async Task LoadVinyl()
    {
        try
        {
            // Nustatome, kad nekreiptų dėmesio į didžiąsias/mažąsias raides JSON'e
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            // Kreipiamės į API
            vinyl = await Http.GetFromJsonAsync<PloksteleDto>("api/Vinyl/7499355", options);

            StateHasChanged(); // Priverstinai atnaujiname vaizdą
        }
        catch (Exception ex)
        {
            Console.WriteLine("Klaida siunčiant užklausą: " + ex.Message);
        }
    }
}