@page "/collections"
@using VinylTapes.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<h1 class="text-3xl font-bold mb-6">Mano sąrašai</h1>

@if (isLoading)
{
    <p>Įkeliam...</p>
}
else if (collections == null || !collections.Any())
{
    <p>Jūsų sąrašai nerasti.</p>
}
else
{
    @foreach (var grp in groupedCollections)
    {
        <div class="mb-8">
            <h2 class="text-xl font-semibold mb-4">@grp.Name</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                @foreach (var v in grp.Ploksteles)
                {
                    <div role="button" class="cursor-pointer" @onclick="@(() => OpenDetailsCollections(v.DiscogsId ?? 0))">
                        <VinylExchange.Client.Components.VinylCard Record="v" />
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private List<SarasaiDto>? collections;
    private bool isLoading = true;
    private string userEmail = "";
    private List<(string Name, List<PloksteleDto> Ploksteles)> groupedCollections = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            userEmail = await JS.InvokeAsync<string>("localStorage.getItem", "userEmail") ?? string.Empty;
        }
        catch
        {
            userEmail = string.Empty;
        }

        if (string.IsNullOrEmpty(userEmail))
        {
            isLoading = false;
            return;
        }

        var url = $"api/Vinyl/my-collections?el_pastas={Uri.EscapeDataString(userEmail)}";
        var resp = await Http.GetAsync(url);
        if (resp.IsSuccessStatusCode)
        {
            collections = await resp.Content.ReadFromJsonAsync<List<SarasaiDto>>();
            // Group collections by type name so entries with same type are shown together
            groupedCollections = collections
                .GroupBy(c => string.IsNullOrEmpty(c.TipasName) ? c.Tipas.ToString() : c.TipasName)
                .Select(g => (Name: g.Key ?? "Sąrašas", Ploksteles: g.SelectMany(x => x.Ploksteles).ToList()))
                .ToList();
        }

        isLoading = false;
    }

    private void OpenDetails(int id, string source)
    {
        Nav.NavigateTo($"/vinyl/{id}?source={source}");
    }

    private void OpenDetailsCollections(int id)
    {
        OpenDetails(id, "collections");
    }

    private void OpenDetailsMainomos(int id)
    {
        OpenDetails(id, "mainomos");
    }
}
